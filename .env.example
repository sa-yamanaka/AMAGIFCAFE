# ==============================
# Supabase
# ==============================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
# サーバー専用。絶対にフロントに露出させないこと
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ==============================
# LINE LIFF
# ==============================
NEXT_PUBLIC_LIFF_ID=1234567890-abcdefgh
# LINE Login チャネルID（IDトークン検証用）。未設定時は LIFF_ID の先頭部分を使う。
NEXT_PUBLIC_LINE_LOGIN_CHANNEL_ID=1234567890
LINE_CHANNEL_SECRET=xxxxxxxxxxxxxxxxx
LINE_CHANNEL_ACCESS_TOKEN=xxxxxxxxxxxxxxxxx

# ==============================
# Stripe
# ==============================
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe 商品(Price)ID - コインパックごと
# 10コイン=¥1,000 / 50コイン=¥5,000 / 100コイン=¥10,000 （1コイン=¥100）
STRIPE_PRICE_COIN_10=price_xxx
STRIPE_PRICE_COIN_50=price_xxx
STRIPE_PRICE_COIN_100=price_xxx

# ==============================
# App
# ==============================
NEXT_PUBLIC_APP_URL=https://your-domain.example.com
